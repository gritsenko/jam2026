{
  "name": "synergy-grid-td",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Synergy Grid TD — playable shell (Tower Defense / Merge on a 3x3 grid). Built with Vite + TypeScript + PixiJS v8.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && node scripts/verify-game-configs.mjs && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:configs": "node scripts/verify-game-configs.mjs"
  },
  "dependencies": {
    "pixi.js": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "sharp": "^0.35.2",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
